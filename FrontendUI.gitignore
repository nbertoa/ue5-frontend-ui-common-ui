# =============================================================================
# Unreal Engine — .gitignore
# Tracks: Source/, Config/, *.uproject, README.md
# Excludes: everything generated, binary, or too large for GitHub
# =============================================================================

# -----------------------------------------------------------------------------
# GENERATED BY UNREAL BUILD TOOL
# -----------------------------------------------------------------------------
Binaries/
Build/
Intermediate/
DerivedDataCache/

# -----------------------------------------------------------------------------
# SAVED DATA (logs, crashes, screenshots, config overrides)
# -----------------------------------------------------------------------------
Saved/

# -----------------------------------------------------------------------------
# CONTENT (assets — too large for GitHub)
# -----------------------------------------------------------------------------
Content/

# -----------------------------------------------------------------------------
# VISUAL STUDIO / RIDER
# -----------------------------------------------------------------------------
.vs/
.idea/
*.suo
*.user
*.sln
*.vcxproj
*.vcxproj.filters

# -----------------------------------------------------------------------------
# UNREAL GENERATED FILES
# -----------------------------------------------------------------------------
*.VC.db
*.opensdf
*.sdf
*.cachefile
*.VC.opendb

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
